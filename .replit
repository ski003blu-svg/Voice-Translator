modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 18458
externalPort = 3000

[userenv]

[userenv.shared]
AGORA_APP_ID = "fdb1404098b9408fad9044213842db02"
AGORA_APP_CERTIFICATE = "cc0bf0917099414a88ea2aefaa7ee6ec"
ELEVENLABS_API_KEY = "sk_68ca128cfb0a8be4745d26b2de2e3e7e86482b7f21d65f89"
